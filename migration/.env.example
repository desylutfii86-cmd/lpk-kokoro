# === Supabase Baru (ganti setelah project baru dibuat) ===
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-REF

# Server-only (jangan expose ke client)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# === AI (opsional, jika pakai fitur translate / AI) ===
# Lovable API key TIDAK jalan di luar Lovable. Ganti dengan salah satu:
OPENAI_API_KEY=
GEMINI_API_KEY=
